# ============================================
# DevOps Butler - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git!

# --- AWS Credentials (Option 1: IAM Keys) ---
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# --- Bedrock API Key (Option 2: Bearer Token) ---
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here

# --- AWS Bedrock Model IDs ---
BEDROCK_CLAUDE_SONNET_MODEL_ID=us.anthropic.claude-sonnet-4-6-20250514-v1:0
BEDROCK_CLAUDE_HAIKU_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_NOVA_PRO_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_NOVA_ACT_MODEL_ID=amazon.nova-act-v1:0
BEDROCK_TITAN_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# --- HuggingFace (FREE tier, optional) ---
HF_TOKEN=

# --- GitHub (Optional - for CI/CD features) ---
GITHUB_TOKEN=

# --- AWS Console Credentials (for Browser Agent) ---
AWS_CONSOLE_EMAIL=your_email@example.com
AWS_CONSOLE_PASSWORD=your_password_here

# --- Budget ---
MONTHLY_BUDGET_USD=100

# --- Slack Notifications (Optional) ---
SLACK_WEBHOOK_URL=

# --- Application ---
LOG_LEVEL=INFO
BUTLER_HOME=~/.butler

# --- Browser Automation ---
ENABLE_BROWSER_AUTOMATION=true
